// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CodingLevel {
  beginner
  intermediate
  advanced
}

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  active
  archived
  paused
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id            String   @id @default(uuid())
  title         String
  tagline       String?
  imageUrl      String
  imagePublicId String
  description   String
  category      String
  mode          String   @default("in-person")
  featured      Boolean  @default(false)
  capacity      Int?
  registered    Int?
  date          DateTime
  endDate       DateTime?
  timeLabel     String?
  location      String
  speakers      String[]
  registerUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Member {
  id             String      @id @default(uuid())
  name           String
  email          String      @unique
  githubUsername String      @unique
  orgName        String
  joinReason     String
  codingLevel    CodingLevel
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Partner {
  id               String   @id @default(uuid())
  name             String
  websiteUrl       String
  logoUrl          String
  logoPublicId     String
  description      String
  email            String   @unique
  partnershipReason String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Project {
  id            String        @id @default(uuid())
  slug          String        @unique
  repoOwner     String
  repoName      String
  imageUrl      String
  imagePublicId String
  tagline       String
  category      String
  status        ProjectStatus @default(active)
  featured      Boolean       @default(false)
  maintainer    String?
  langColor     String?

  ghDescription  String?
  ghLanguage     String?
  ghTopics       String[]
  ghStars        Int       @default(0)
  ghForks        Int       @default(0)
  ghOpenIssues   Int       @default(0)
  ghContributors Int       @default(0)
  ghPullRequests Int       @default(0)
  ghPushedAt     DateTime?
  lastFetchedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoOwner, repoName])
}
