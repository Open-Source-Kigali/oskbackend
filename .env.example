# Environment variables for development
PORT=3000
NODE_ENV=development

# Database connection string for development
DATABASE_URL="postgresql://user:password@localhost:5432/oskbackend?schema=public"

# Shared API key for admin-only endpoints
ADMIN_API_KEY=replace-with-a-long-string

# CORS origins for development
CORS_ORIGINS=http://localhost:5173, http://localhost:5174

# Cloudinary configuration for development
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# GitHub fine-grained PAT (public repo read) for /projects refresh
GITHUB_TOKEN=
